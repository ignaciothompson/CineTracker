# Copiá este archivo a .env y completá los valores.
# En Dokploy: pegalas en la sección "Environment" del servicio, no hace falta el archivo.

ANTHROPIC_API_KEY=sk-ant-...
# Opcional: modelo por defecto si no elegís uno en la app (Haiku 4.5 recomendado)
ANTHROPIC_MODEL=claude-sonnet-5

# Puerto host de Docker (PocketBase + frontend build).
# 5173 = solo Docker → http://localhost:5173
# 8092 = backend mientras corrés `npm run dev` en web/ → app en http://localhost:5173
HOST_PORT=5173
